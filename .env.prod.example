# --- App ---
APP_URL="http://<server_ip>:3000"
SESSION_COOKIE_NAME="dowhat_session"
# 走 HTTP 必须为 false；后续上 HTTPS 改 true 或删掉这一行（自动按 NODE_ENV 推断）
COOKIE_SECURE="false"

# --- Database (Docker 内网主机名) ---
POSTGRES_USER="dowhat"
POSTGRES_PASSWORD="please-change-me"
POSTGRES_DB="dowhat"
DATABASE_URL="postgresql://dowhat:please-change-me@postgres:5432/dowhat?schema=public"

# --- Redis ---
REDIS_URL="redis://redis:6379"

# --- Mail (Mailpit 容器内网) ---
SMTP_HOST="mailpit"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="DoWhat <noreply@dowhat.local>"

# --- Asset CDN (P3) ---
NEXT_PUBLIC_ASSET_BASE=""

# --- Nginx (可选) ---
# 如果使用自定义域名，修改 docker/nginx/default.conf 中的 server_name
# 例如: server_name yourdomain.com www.yourdomain.com;
